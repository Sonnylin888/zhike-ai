{
  "version": "2.0",
  "envId": "zhike-prod",
  "app": {
    "serviceName": "zhike",
    "root": "./",
    "framework": "next",
    "installCommand": "npm install --legacy-peer-deps",
    "buildCommand": "npm run build",
    "startCommand": "npm start",
    "outputDir": ".next",
    "deployPath": "/",
    "envVariables": {
      "NEXT_PUBLIC_APP_NAME": "智课",
      "NEXT_PUBLIC_APP_VERSION": "2.0.0",
      "NEXT_PUBLIC_DEMO_MODE": "true"
    },
    "ignore": [
      "node_modules",
      ".git",
      ".next/cache",
      "out",
      "build",
      "release",
      "logs",
      "dist-electron",
      "electron",
      "*.dmg",
      "*.exe",
      "*.app",
      "win-unpacked",
      "mac-arm64",
      "*.log",
      ".DS_Store"
    ]
  }
}
